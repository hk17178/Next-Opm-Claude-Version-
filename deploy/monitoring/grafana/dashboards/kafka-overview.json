{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Messages In/Out Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(kafka_server_brokertopicmetrics_messagesin_total[5m])) by (topic)",
          "legendFormat": "In - {{ topic }}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(kafka_server_brokertopicmetrics_bytesout_total[5m])) by (topic)",
          "legendFormat": "Out - {{ topic }}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 2,
      "title": "Consumer Group Lag",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(kafka_consumergroup_lag_sum) by (consumergroup)",
          "legendFormat": "{{ consumergroup }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 50000,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "red", "value": 10000 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Topic Partition Distribution",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "count(kafka_topic_partition_current_offset) by (topic)",
          "legendFormat": "{{ topic }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Broker Status",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "count(kafka_server_replicamanager_leadercount)",
          "legendFormat": "Active Brokers",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["opsnexus", "kafka"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Kafka Overview",
  "uid": "kafka-overview",
  "version": 1
}
