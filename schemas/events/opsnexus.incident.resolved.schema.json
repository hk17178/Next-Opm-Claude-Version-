{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opsnexus.io/schemas/events/opsnexus.incident.resolved.v1",
  "title": "Incident Resolved Event",
  "description": "Emitted by svc-incident when an incident is resolved, including MTTA/MTTR metrics.",
  "type": "object",
  "required": ["specversion", "id", "type", "source", "time", "data"],
  "properties": {
    "specversion": { "type": "string", "const": "1.0" },
    "id": { "type": "string", "format": "uuid" },
    "type": { "type": "string", "const": "opsnexus.incident.resolved" },
    "source": { "type": "string" },
    "time": { "type": "string", "format": "date-time" },
    "datacontenttype": { "type": "string", "const": "application/json" },
    "data": {
      "type": "object",
      "required": ["incident_id", "title", "severity", "status", "detected_at", "resolved_at"],
      "properties": {
        "incident_id": { "type": "string" },
        "title": { "type": "string" },
        "severity": { "type": "string", "enum": ["P0", "P1", "P2", "P3", "P4"] },
        "status": { "type": "string", "const": "resolved" },
        "root_cause_category": {
          "type": "string",
          "enum": ["human_action", "change_caused", "system_fault", "external", "unknown"]
        },
        "root_cause_summary": { "type": "string" },
        "assignee": {
          "type": "object",
          "properties": {
            "user_id": { "type": "string" },
            "name": { "type": "string" }
          }
        },
        "detected_at": { "type": "string", "format": "date-time" },
        "acknowledged_at": { "type": "string", "format": "date-time" },
        "resolved_at": { "type": "string", "format": "date-time" },
        "mtta_seconds": { "type": "integer", "description": "Mean Time To Acknowledge in seconds" },
        "mttr_seconds": { "type": "integer", "description": "Mean Time To Resolve in seconds" },
        "affected_assets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "business_unit": { "type": "string" },
        "resolution": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
