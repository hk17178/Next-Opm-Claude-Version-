{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opsnexus.io/schemas/events/opsnexus.ai.analysis.done.v1",
  "title": "AI Analysis Done Event",
  "description": "Emitted by svc-ai when an intelligent analysis task completes (root cause analysis, anomaly detection, prediction).",
  "type": "object",
  "required": [
    "specversion",
    "id",
    "type",
    "source",
    "time",
    "data"
  ],
  "properties": {
    "specversion": {
      "type": "string",
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "type": {
      "type": "string",
      "const": "opsnexus.ai.analysis.done"
    },
    "source": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "datacontenttype": {
      "type": "string",
      "const": "application/json"
    },
    "data": {
      "type": "object",
      "required": [
        "analysis_id",
        "analysis_type",
        "status",
        "completed_at"
      ],
      "properties": {
        "analysis_id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique analysis task identifier"
        },
        "analysis_type": {
          "type": "string",
          "enum": ["root_cause", "anomaly_detection", "prediction", "correlation", "log_summary"],
          "description": "Type of AI analysis performed"
        },
        "status": {
          "type": "string",
          "enum": ["success", "partial", "failed"],
          "description": "Analysis completion status"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        },
        "trigger_event_id": {
          "type": "string",
          "description": "The event ID that triggered this analysis"
        },
        "incident_id": {
          "type": "string",
          "format": "uuid",
          "description": "Related incident if applicable"
        },
        "result": {
          "type": "object",
          "properties": {
            "summary": {
              "type": "string",
              "description": "Human-readable analysis summary"
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Confidence score of the analysis result"
            },
            "root_causes": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "description": { "type": "string" },
                  "probability": { "type": "number", "minimum": 0, "maximum": 1 },
                  "related_ci_ids": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              },
              "description": "Identified root causes with probability scores"
            },
            "recommendations": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Suggested remediation actions"
            }
          },
          "additionalProperties": true
        },
        "model_version": {
          "type": "string",
          "description": "AI model version used for this analysis"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
